# Kineticz environment configuration.
# Copy to .env and fill in real values before `docker run --env-file .env`.

# HTTP server
PORT=8080

# MongoDB Atlas (must be a replica set; transactions are required)
MONGO_URI=mongodb+srv://USER:PASS@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=kineticz

# Audit signing key. Generate once with:
#   openssl rand -hex 32
# Persist the resulting 64-char hex string; rotating it invalidates Verify
# against entries signed with the old key.
KINETICZ_ED25519_SEED=

# Vertex AI Generative AI (Gemini)
GEMINI_PROJECT_ID=your-gcp-project
GEMINI_LOCATION=us-central1
GEMINI_MODEL=gemini-3.5-flash
# Local dev: paste a short-lived token from `gcloud auth print-access-token`.
# Cloud Run production: leave blank. envTokenFunc fetches a token from the
# instance metadata server when this var is empty.
GOOGLE_ACCESS_TOKEN=

# Fivetran webhook HMAC shared secret
FIVETRAN_SECRET=

# Elastic (BM25 + KNN over RRF)
ELASTIC_URL=https://elastic.example.com
# API key for the secured cluster. Create with POST /_security/api_key and use
# the "encoded" field verbatim (already base64; the client does not re-encode).
ELASTIC_API_KEY=
# E5 inference ENDPOINT id used by query_vector_builder.model_id. Default is the
# ES 9.x preconfigured endpoint. For a custom endpoint, set this and run
# scripts/index_elastic.sh, which creates it from model_id .multilingual-e5-small.
ELASTIC_INFERENCE_MODEL=.multilingual-e5-small-elasticsearch

# Dynatrace (DQL + bizevents)
DYNATRACE_URL=https://your-tenant.live.dynatrace.com
DYNATRACE_TOKEN=

# Arize Phoenix (OpenTelemetry trace export for pipeline observability).
# The deterministic gate runs locally (parses-as-Go + preserves exported
# signatures); Phoenix observes the decision rather than scoring it.
#
# Phoenix Cloud endpoints are space-scoped. Use the full space path including
# /v1/traces, for example:
#   https://app.phoenix.arize.com/s/<your-space>/v1/traces
# A bare https://app.phoenix.arize.com/v1/traces returns 401 (empty body).
# Auth is a JWT system key sent as "authorization: Bearer <key>". The bare
# "api_key" header form is rejected as an invalid token on Phoenix Cloud.
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space/v1/traces
PHOENIX_API_KEY=

# GitLab (commit + MR)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_PROJECT_ID=group/project
GITLAB_TARGET_BRANCH=main
